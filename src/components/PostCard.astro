---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, date, excerpt } = post.data;
const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group rounded-lg p-4 -mx-4 transition-colors hover:bg-neutral-50">
  <a href={`/posts/${post.id}`} class="no-underline">
    <h2 class="text-xl font-semibold text-neutral-900 group-hover:text-neutral-700 transition-colors">
      {title}
    </h2>
    <time datetime={date.toISOString()} class="mt-1 block text-sm text-neutral-400">
      {formattedDate}
    </time>
    <p class="mt-3 text-neutral-500 leading-relaxed">
      {excerpt}
    </p>
  </a>
</article>
