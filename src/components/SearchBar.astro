<button
  id="search-toggle"
  class="flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm text-neutral-400 transition-colors hover:bg-neutral-100 hover:text-neutral-600"
  aria-label="搜索"
  type="button"
>
  <svg
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="11" cy="11" r="8" />
    <path d="m21 21-4.35-4.35" />
  </svg>
  <span class="hidden sm:inline">搜索</span>
</button>

<div
  id="search-overlay"
  class="fixed inset-0 z-50 hidden items-start justify-center bg-white/80 pt-[15vh] backdrop-blur-sm"
>
  <div class="mx-auto w-full max-w-lg px-4">
    <div class="relative">
      <svg
        class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35"></path>
      </svg>
      <input
        id="search-input"
        class="w-full rounded-xl border border-neutral-200 bg-white py-3 pl-10 pr-10 text-neutral-900 shadow-sm outline-none transition-shadow focus:border-neutral-300 focus:shadow-md"
        type="text"
        placeholder="搜索文章..."
        autocomplete="off"
      />
      <button
        id="search-close"
        class="absolute right-3 top-1/2 -translate-y-1/2 rounded p-0.5 text-neutral-400 transition-colors hover:text-neutral-600"
        type="button"
        aria-label="关闭搜索"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 6 6 18" /><path d="m6 6 12 12" />
        </svg>
      </button>
    </div>
    <div id="search-results" class="mt-3 max-h-96 overflow-y-auto"></div>
  </div>
</div>

<script>
  // @ts-nocheck
  var base = document.querySelector('meta[name="base-url"]')?.getAttribute("content") || "/";

  async function loadSearchData() {
    try {
      var res = await fetch(base + "search.json");
      return await res.json();
    } catch (e) {
      return [];
    }
  }

  var toggle = document.getElementById("search-toggle");
  var overlay = document.getElementById("search-overlay");
  var input = document.getElementById("search-input");
  var close = document.getElementById("search-close");
  var results = document.getElementById("search-results");

  var posts = [];

  function closeSearch() {
    if (overlay) {
      overlay.classList.add("hidden");
      overlay.classList.remove("flex");
    }
    if (input) input.value = "";
    if (results) results.innerHTML = "";
  }

  toggle && toggle.addEventListener("click", function () {
    if (overlay) {
      overlay.classList.remove("hidden");
      overlay.classList.add("flex");
    }
    if (input) input.focus();
    if (posts.length === 0) {
      loadSearchData().then(function (data) { posts = data; });
    }
  });

  close && close.addEventListener("click", closeSearch);

  overlay && overlay.addEventListener("click", function (e) {
    if (e.target === overlay) closeSearch();
  });

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && overlay && !overlay.classList.contains("hidden")) {
      closeSearch();
    }
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      if (overlay) {
        overlay.classList.remove("hidden");
        overlay.classList.add("flex");
      }
      if (input) input.focus();
      if (posts.length === 0) {
        loadSearchData().then(function (data) { posts = data; });
      }
    }
  });

  input && input.addEventListener("input", function () {
    if (!results || !input) return;
    var query = input.value.trim().toLowerCase();
    if (!query) {
      results.innerHTML = "";
      return;
    }
    var filtered = posts.filter(function (p) {
      return p.title.toLowerCase().indexOf(query) !== -1 ||
        p.excerpt.toLowerCase().indexOf(query) !== -1 ||
        (p.tags || []).some(function (t) { return t.toLowerCase().indexOf(query) !== -1; });
    }).slice(0, 8);

    if (filtered.length === 0) {
      results.innerHTML = '<p class="text-center text-sm text-neutral-400 py-8">没有找到相关文章</p>';
      return;
    }

    results.innerHTML = filtered.map(function (p) {
      var tagsHtml = "";
      if (p.tags && p.tags.length) {
        tagsHtml = '<span class="mt-1 flex flex-wrap gap-1">' +
          p.tags.map(function (t) {
            return '<span class="rounded-full bg-neutral-100 px-1.5 py-0.5 text-xs text-neutral-500">' + t + '</span>';
          }).join("") + '</span>';
      }
      return '<a href="' + base + p.url.replace(/^\//, "") + '" class="block rounded-lg px-4 py-3 transition-colors hover:bg-neutral-50">' +
        '<span class="text-sm font-medium text-neutral-900">' + p.title + '</span>' +
        '<span class="ml-2 text-xs text-neutral-400">' + p.date + '</span>' +
        tagsHtml + '</a>';
    }).join("");
  });
</script>
